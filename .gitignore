# Python
__pycache__/
*.py[cod]
*$py.class

# Entornos virtuales
.venv/
venv/
env/
ENV/

# Jupyter
.ipynb_checkpoints/

# Archivos de entorno y secretos
.env
.env.*

# Herramientas y caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Sistema operativo / editor
.DS_Store
Thumbs.db
.vscode/
.idea/

# Data del proyecto: no subir datasets ni archivos procesados
data/raw/*
data/processed/*
!data/raw/.gitkeep
!data/processed/.gitkeep

# Outputs generados
outputs/figures/*
outputs/tables/*
outputs/reports/*
!outputs/figures/.gitkeep
!outputs/tables/.gitkeep
!outputs/reports/.gitkeep

# Reportes o artefactos generados opcionales
*.log
